{
  "name": "vue-pact-go-rest",
  "private": true,
  "packageManager": "pnpm@10.18.1",
  "engines": {
    "node": "24.14.0",
    "pnpm": ">=10.18.1"
  },
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "format": "turbo format",
    "dev": "turbo dev",
    "openapi:validate": "spectral lint openapi/openapi.yaml --ruleset openapi/spectral.yaml"
  },
  "devDependencies": {
    "@stoplight/spectral-cli": "6.15.0",
    "turbo": "2.8.16"
  },
  "pnpm": {
    "overrides": {
      "magic-string": "0.30.21"
    },
    "allowedDeprecatedVersions": {
      "glob": "7",
      "inflight": "1"
    }
  }
}
