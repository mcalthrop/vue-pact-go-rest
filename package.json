{
  "name": "vue-pact-go-rest",
  "private": true,
  "packageManager": "pnpm@10.18.1",
  "engines": {
    "node": "24.14.0",
    "pnpm": ">=10.18.1"
  },
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "format": "turbo format",
    "format:check": "turbo format:check",
    "dev": "turbo dev",
    "coverage": "turbo coverage",
    "type-check": "turbo type-check",
    "generate:types": "turbo generate:types",
    "pact:consumer-test": "turbo pact:consumer-test",
    "pact:consumer-publish": "turbo pact:consumer-publish",
    "pact:provider-verify": "turbo pact:provider-verify",
    "openapi:validate": "redocly lint openapi/openapi.yaml",
    "lint-staged": "lint-staged && turbo lint-staged --concurrency=1",
    "prepare": "husky"
  },
  "devDependencies": {
    "@redocly/cli": "2.21.1",
    "husky": "9.1.7",
    "lint-staged": "16.3.3",
    "prettier": "3.8.1",
    "turbo": "2.8.16"
  }
}
