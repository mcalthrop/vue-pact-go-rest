{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "bin/**"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "coverage": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**", "*.out"]
    },
    "type-check": {
      "outputs": []
    },
    "lint": {
      "cache": false,
      "outputs": []
    },
    "lint-staged": {
      "cache": false,
      "outputs": []
    },
    "format": {
      "outputs": []
    },
    "format:check": {
      "outputs": []
    },
    "generate:types": {
      "outputs": ["internal/gen/**", "src/types/**"]
    },
    "pact:consumer-test": {
      "cache": false
    },
    "pact:consumer-publish": {
      "dependsOn": ["pact:consumer-test"],
      "cache": false,
      "passThroughEnv": ["PACT_CONSUMER_BRANCH"]
    },
    "pact:provider-verify": {
      "cache": false,
      "passThroughEnv": ["PACT_PROVIDER_BRANCH", "PACT_PROVIDER_VERSION", "PACT_PUBLISH_RESULTS"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "prod": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true
    }
  }
}
