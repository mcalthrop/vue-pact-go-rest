{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "coverage": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "type-check": {
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "format": {
      "outputs": []
    },
    "format:check": {
      "outputs": []
    },
    "generate:types": {
      "outputs": ["internal/gen/**", "src/types/**"]
    },
    "pact:consumer-test": {
      "cache": false
    },
    "pact:consumer-publish": {
      "dependsOn": ["pact:consumer-test"],
      "cache": false
    },
    "pact:provider-verify": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
