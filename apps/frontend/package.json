{
  "name": "@vue-pact-go-rest/frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "build-only": "vite build",
    "prod": "vite preview",
    "type-check": "vue-tsc --build",
    "test": "vitest run",
    "coverage": "vitest run --coverage --project unit",
    "test:watch": "vitest",
    "lint": "run-s lint:*",
    "lint:eslint": "eslint . --fix --cache",
    "lint:knip": "knip",
    "lint:oxlint": "oxlint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate:types": "openapi-typescript ../../openapi/openapi.yaml -o src/types/api.gen.ts",
    "pact:consumer-test": "vitest run --project pact",
    "pact:consumer-publish": "pact-broker publish pacts --consumer-app-version=$(git rev-parse HEAD) --branch=${PACT_CONSUMER_BRANCH:-$(git rev-parse --abbrev-ref HEAD)} --broker-base-url=http://localhost:9292 --broker-username=pact --broker-password=pact",
    "lint-staged": "lint-staged"
  },
  "dependencies": {
    "vue": "3.5.30",
    "vue-router": "5.0.3"
  },
  "devDependencies": {
    "@pact-foundation/pact": "16.3.0",
    "@pact-foundation/pact-cli": "16.1.7",
    "@tsconfig/node24": "24.0.4",
    "@types/jsdom": "28.0.0",
    "@types/node": "24.12.0",
    "@vitejs/plugin-vue": "6.0.5",
    "@vitest/coverage-v8": "4.1.0",
    "@vitest/eslint-plugin": "1.6.11",
    "@vue/eslint-config-typescript": "14.7.0",
    "@vue/test-utils": "2.4.6",
    "@vue/tsconfig": "0.9.0",
    "eslint": "10.0.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-oxlint": "1.54.0",
    "eslint-plugin-vue": "10.8.0",
    "jiti": "2.6.1",
    "jsdom": "28.1.0",
    "knip": "5.86.0",
    "lint-staged": "16.3.3",
    "msw": "2.12.10",
    "npm-run-all2": "8.0.4",
    "openapi-typescript": "7.13.0",
    "oxlint": "1.55.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "vite": "8.0.5",
    "vite-plugin-vue-devtools": "8.0.7",
    "vitest": "4.1.0",
    "vue-tsc": "3.2.5"
  },
  "engines": {
    "node": "24.14.0",
    "pnpm": ">=10.18.1"
  }
}
