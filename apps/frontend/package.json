{
  "name": "@vue-pact-go-rest/frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "build-only": "vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "eslint . --fix",
    "generate:types": "openapi-typescript ../../openapi/openapi.yaml -o src/types/api.gen.ts"
  },
  "dependencies": {
    "vue": "3.5.29",
    "vue-router": "5.0.3"
  },
  "devDependencies": {
    "@tsconfig/node24": "24.0.4",
    "@types/jsdom": "28.0.0",
    "@types/node": "24.11.0",
    "@vitejs/plugin-vue": "6.0.4",
    "@vitest/eslint-plugin": "1.6.9",
    "@vue/eslint-config-typescript": "14.7.0",
    "@vue/test-utils": "2.4.6",
    "@vue/tsconfig": "0.8.1",
    "eslint": "10.0.2",
    "eslint-plugin-oxlint": "1.50.0",
    "eslint-plugin-vue": "10.8.0",
    "jiti": "2.6.1",
    "jsdom": "28.1.0",
    "npm-run-all2": "8.0.4",
    "openapi-typescript": "7.13.0",
    "oxlint": "1.50.0",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vite-plugin-vue-devtools": "8.0.6",
    "vitest": "4.0.18",
    "vue-tsc": "3.2.5"
  },
  "engines": {
    "node": "24.14.0",
    "pnpm": ">=10.18.1"
  }
}
